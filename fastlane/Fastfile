default_platform(:ios)

# ── Configuration ──────────────────────────────────────────────────────────────
PROJECT      = "GitPhotos.xcodeproj"
SCHEME       = "GitPhotos"
BUNDLE_ID    = "com.gitphotos.gitphotos"
TEAM_ID      = "L6LUXM357X"
OUTPUT_DIR   = "build"
IPA_NAME     = "GitPhotos.ipa"

platform :ios do
  # Loads an App Store Connect API key from environment variables.
  # Required secrets: ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_CONTENT (the raw .p8 text, base64 optional).
  def asc_api_key
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: ENV["ASC_KEY_CONTENT_BASE64"] == "true",
      in_house: false
    )
  end

  desc "Build a signed App Store .ipa"
  lane :build do
    api_key = asc_api_key

    # The keychain, certificate, and provisioning profile are installed by the
    # workflow before fastlane runs (see .github/workflows/release.yml).

    # Bump the build number so every upload is unique. BUILD_NUMBER is supplied by the workflow.
    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || latest_testflight_build_number(api_key: api_key).to_i + 1,
      xcodeproj: PROJECT
    )

    # Force manual signing with the profile/cert the workflow installed.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: PROJECT,
      team_id: TEAM_ID,
      bundle_identifier: BUNDLE_ID,
      code_sign_identity: "Apple Distribution",
      profile_name: ENV.fetch("PROVISIONING_PROFILE_NAME")
    )

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      clean: true,
      output_directory: OUTPUT_DIR,
      output_name: IPA_NAME,
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        teamID: TEAM_ID,
        provisioningProfiles: {
          BUNDLE_ID => ENV.fetch("PROVISIONING_PROFILE_NAME")
        }
      }
    )
  end

  desc "Build and upload to TestFlight only"
  lane :beta do
    api_key = asc_api_key
    build
    upload_to_testflight(
      api_key: api_key,
      ipa: File.join(OUTPUT_DIR, IPA_NAME),
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build, upload, and submit the binary for App Store review"
  lane :release do
    api_key = asc_api_key
    build
    upload_to_app_store(
      api_key: api_key,
      ipa: File.join(OUTPUT_DIR, IPA_NAME),
      # Metadata & screenshots are managed in App Store Connect, not in this repo.
      skip_metadata: true,
      skip_screenshots: true,
      skip_app_version_update: false,
      submit_for_review: true,
      automatic_release: false,
      force: true, # skip the interactive HTML preview
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false
      }
    )
  end
end
